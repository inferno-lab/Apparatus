{
  "name": "@apparatus/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm --experimental-specifier-resolution=node src/index.ts",
    "build": "pnpm --filter @apparatus/dashboard build && tsc && cp -r src/dist-dashboard dist/",
    "start": "node dist/index.js",
    "tui": "node --loader ts-node/esm --experimental-specifier-resolution=node src/tui/index.ts",
    "escape": "node --loader ts-node/esm --experimental-specifier-resolution=node src/escape/index.ts",
    "imposter": "node --loader ts-node/esm --experimental-specifier-resolution=node src/imposter/index.ts",
    "sidecar": "node --loader ts-node/esm --experimental-specifier-resolution=node src/sidecar/index.ts",
    "gen-self-signed": "mkdir -p certs && openssl req -x509 -newkey rsa:2048 -keyout certs/server.key -out certs/server.crt -days 365 -nodes -subj \"/CN=localhost\"",
    "lint": "echo \"(lint placeholder)\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "aedes": "^0.51.3",
    "axios": "^1.13.2",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "compression": "^1.8.1",
    "eventsource": "^2.0.2",
    "express": "^4.19.2",
    "graphql": "^16.12.0",
    "graphql-http": "^1.22.4",
    "ipaddr.js": "^2.3.0",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "undici": "^7.16.0",
    "ws": "^8.18.3",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/blessed": "^0.1.25",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.12.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@types/yamljs": "^0.2.34",
    "esbuild": "^0.27.2",
    "pino-pretty": "^11.2.2",
    "pkg": "^5.8.1",
    "postject": "^1.0.0-alpha.6",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2"
  }
}
