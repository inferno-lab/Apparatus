{
  "name": "@apparatus/cli",
  "version": "0.1.0",
  "description": "CLI and REPL for Apparatus API",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "apparatus": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@apparatus/client": "workspace:*",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
