flowchart LR
    Input["Fuzzer Request\nmethod/path/body"] --> App["Apparatus Ingress"]
    App --> MTD["MTD Prefix Check"]
    MTD --> Deception["Deception + Tarpit"]
    Deception --> WAF{"WAF Rule Match?"}
    WAF -->|Yes| Block["Blocked Response\n403 + blocked=true"]
    WAF -->|No| Handler["Route Handler Executes"]
    Handler --> Output["Result Classification\npass, block, or timeout"]

