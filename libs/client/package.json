{
  "name": "@atlascrew/apparatus-sdk",
  "version": "0.9.2",
  "description": "TypeScript API client for Apparatus",
  "author": "Nicholas Crew Ferguson <nick@atlascrew.dev> (https://atlascrew.dev)",
  "keywords": [
    "security-research",
    "network-simulation",
    "security-testing",
    "synapse",
    "horizon"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NickCrew/Apparatus.git",
    "directory": "libs/client"
  },
  "homepage": "https://apparatus.atlascrew.dev",
  "bugs": "https://github.com/NickCrew/Apparatus/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.12.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
